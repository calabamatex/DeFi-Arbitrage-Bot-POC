# Arbitrum Sepolia Testnet (Chain ID: 421614)
#
# NOTE: This is a TESTNET config for deployment testing.
# DEX liquidity is minimal — use Anvil mainnet forks for functional arb testing.
#
# Aave V3 testnet deployment (from aave-address-book)
AAVE_POOL_PROVIDER=0xB25a5D144626a0D488e52AE717A051a2E9997076
#
# Uniswap V3 (official testnet deployment)
# NOTE: Only SwapRouter02 is deployed on Arbitrum Sepolia (no original SwapRouter).
# SwapRouter02 has a different struct (no deadline field), so our V3 adapter
# can deploy but won't execute swaps. Use Anvil mainnet forks for swap testing.
UNISWAP_V3_ROUTER=0x101F443B4d1b059569D643917553c771E1b9663E
UNISWAP_V3_QUOTER=0x2779a0CC1c3e0E44D2542EC3e79e3864Ae93Ef0B
#
# SushiSwap V2 (same deterministic address as mainnet)
V2_ROUTER=0x1b02dA8Cb0d097eB8D57A175b88c7D8b47997506
V2_DEX_NAME=SushiSwap
#
MIN_PROFIT=100000
MAX_SLIPPAGE_BPS=200
