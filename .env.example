# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# SECURITY WARNING
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# NEVER use default, empty, or example passwords in production.
# All secrets below marked (REQUIRED) will cause docker-compose
# to refuse to start if left empty — this is intentional.
#
# Generate strong passwords:
#   openssl rand -base64 32
#
# For production deployments, use a secrets manager (Vault,
# AWS Secrets Manager, etc.) rather than a .env file.
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

# ============================================================
# DOCKER / INFRASTRUCTURE SECRETS (REQUIRED)
# ============================================================
# DEV_MODE gates permissive defaults in docker-compose.yml.
# Set to "true" ONLY for local development — never in production.
DEV_MODE=false

# PostgreSQL — docker-compose will fail to start if unset
POSTGRES_PASSWORD=
POSTGRES_USER=postgres
POSTGRES_DB=arbitrage_bot

# Redis — docker-compose will fail to start if unset
REDIS_PASSWORD=

# Health endpoint bearer token (recommended for production)
HEALTH_AUTH_TOKEN=

# Grafana admin password — required when using 'monitoring' profile
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ADMIN_USER=admin

# PgAdmin password — required when using 'tools' profile
PGADMIN_PASSWORD=
PGADMIN_EMAIL=admin@arbitrage.local

# Redis Commander password — required when using 'tools' profile
REDIS_COMMANDER_PASSWORD=
REDIS_COMMANDER_USER=admin

# Optional: bind database/redis ports to 0.0.0.0 for external access
# (defaults to 127.0.0.1 for security)
# POSTGRES_HOST_BIND=0.0.0.0
# REDIS_HOST_BIND=0.0.0.0

# Optional: configure service ports and bind addresses
# Bot services default to 0.0.0.0 (all interfaces); override to restrict
# ARB_BOT_HOST_BIND=127.0.0.1
# ARB_BOT_PORT=8080
# LIQ_BOT_HOST_BIND=127.0.0.1
# LIQ_BOT_PORT=8082
# DASHBOARD_API_HOST_BIND=127.0.0.1
# DASHBOARD_API_PORT=8000
# DASHBOARD_WEB_HOST_BIND=127.0.0.1
# DASHBOARD_WEB_PORT=3000

# ============================================================
# KEY MANAGEMENT — NEVER store private keys in this file!
# ============================================================
# Option 1 (recommended): Encrypted keystore
#   python -m src.utils.key_manager create
#   Then set the path below:
KEYSTORE_FILE=
#
# Option 2: Runtime env var (CI/Docker only — never save to file)
#   export PRIVATE_KEY=0x...
#
# For Foundry deployments, use encrypted keystores:
#   cast wallet import deployer --interactive
#   ./script/deploy.sh polygon --broadcast
# ============================================================

# RPC URLs — Mainnets (HTTP)
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org

# RPC URLs — Mainnets (WebSocket, optional — enables event-driven scanning)
# When set, the bot subscribes to newHeads via WebSocket and scans on each
# new block instead of polling every 5 seconds. Falls back to polling if
# the WebSocket connection fails.
# POLYGON_RPC_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_RPC_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# OPTIMISM_RPC_WS_URL=wss://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# RPC URLs — Testnets
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# API Keys for Contract Verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key
OPTIMISM_API_KEY=your_optimism_api_key
BASESCAN_API_KEY=your_basescan_api_key

# CoinMarketCap API (for gas reporting)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Hardhat Settings
FORKING=false
REPORT_GAS=true

# Database — replace <POSTGRES_PASSWORD> with the same value as POSTGRES_PASSWORD above
# Inside Docker, this is auto-constructed; only needed for external tools
DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@localhost:5432/arbitrage_bot

# Redis — replace <REDIS_PASSWORD> with the same value as REDIS_PASSWORD above
# Inside Docker, this is auto-constructed; only needed for external tools
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Tenderly (for transaction simulation)
TENDERLY_ACCESS_KEY=your_tenderly_access_key
TENDERLY_PROJECT=your_tenderly_project
TENDERLY_USERNAME=your_tenderly_username

# Application Settings
MIN_PROFIT_USD=10
MAX_GAS_PRICE_GWEI=100
EXECUTION_MODE=testnet

# Contract Addresses (set after deployment)
# FLASH_LOAN_ARBITRAGE_ADDRESS=0x...
# UNISWAP_V3_ADAPTER_ADDRESS=0x...
# UNISWAP_V2_ADAPTER_ADDRESS=0x...
# CURVE_ADAPTER_ADDRESS=0x...

# Balancer Flash Loans (0% fee)
BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
# BALANCER_FLASH_LOAN_ADDRESS=0x...

# Liquidation Bot
LIQUIDATION_ENABLED=false
LIQUIDATION_MIN_PROFIT_USD=50
LIQUIDATION_SCAN_INTERVAL=30
AAVE_DATA_PROVIDER=0x69FA688f1Dc47d4B5d8029D5a35FB7a548310654
# FLASH_LOAN_LIQUIDATOR_ADDRESS=0x...
